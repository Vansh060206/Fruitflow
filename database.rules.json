{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["phone", "email", "role", "driverStatus"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'wholesaler')"
      }
    },
    "inventory": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "orders": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt", "status"]
    },
    "retailer_orders": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt", "status"]
    },
    "driver_orders": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["status", "createdAt"]
    },
    "order_alerts": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt"]
    },
    "dispatch_alerts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "negotiation_counts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "wastage": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "retailer_favorites": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "mandi_prices": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["state", "mandiName", "commodity"]
    },
    "otps": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["timestamp"]
    },
    "stock_requests": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
          ".indexOn": ["createdAt", "type", "read"]
      }
    }
  }
}